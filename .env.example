# Copy this file to .env and fill in the providers you want to enable.
# Keep .env private. It is intentionally ignored by git.

# Alpaca: market data, premarket/extended-hours bars, quotes, trades, and news.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# SEC EDGAR: no API key, but a descriptive User-Agent is required.
# Example: Your Name your.email@example.com
SEC_USER_AGENT=
SEC_DATA_BASE_URL=https://data.sec.gov
SEC_WWW_BASE_URL=https://www.sec.gov

# Financial Modeling Prep: optional float/profile/fundamentals fallback.
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable

# Alpha Vantage: optional news/sentiment/fundamentals fallback.
ALPHA_VANTAGE_API_KEY=

# Optional app defaults.
SCREENER_CONFIG_DIR=config
SCREENER_DATA_DIR=data
